{
  "name": "LUITIAN Site",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "luitian-site",
  "workspaceFolder": "/app",
  "forwardPorts": [3000],
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  }
}
